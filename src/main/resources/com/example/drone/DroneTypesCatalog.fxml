<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/javafx" fx:controller="com.example.drone.Frontend.DroneTypesController"
      spacing="10" alignment="CENTER" style="-fx-padding: 20;">
    <!-- ListView to display drones -->
    <ListView fx:id="droneTypesListView" prefWidth="400" prefHeight="300" />

    <!-- Button to load drones -->
    <Button text="Load Drones" onAction="#loadDrones" />
</VBox>
