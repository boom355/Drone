<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/javafx" fx:controller="com.example.drone.Frontend.DronesController"
      spacing="10" alignment="CENTER" prefWidth="800" prefHeight="600">

    <!-- Button to load drones -->
    <Button text="Load Drones" onAction="#loadDrones"/>

    <!-- ListView to display drones -->
    <ListView fx:id="dronesListView" prefWidth="400" prefHeight="150" onMouseClicked="#onDroneSelected"/>

    <!-- TextArea to display dynamic data of the selected drone -->
    <TextArea fx:id="droneDynamicsDisplay" editable="false" prefWidth="600" prefHeight="300"/>
</VBox>
